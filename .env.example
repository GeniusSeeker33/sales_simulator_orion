# Orion Sales Simulator — Required Environment Variables
# Copy this file to .env.local for local development.
# In production: add all vars to Vercel → Settings → Environment Variables.
# NEVER commit .env or .env.local to git.

# ─────────────────────────────────────────────
# GENIUSSEEKER IDENTITY SERVICE
# Powers GeniusDollars balance + redemption
# Local dev: http://localhost:8787
# Production: wherever identity-service is deployed (e.g. https://identity.geniusseeker.com)
# ─────────────────────────────────────────────
VITE_IDENTITY_SERVICE_URL=http://localhost:8787

# ─────────────────────────────────────────────
# ALREADY CONFIGURED
# ─────────────────────────────────────────────

# OpenAI (powers AI Sales Simulator customer responses and call scoring)
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# MICROSOFT BUSINESS CENTRAL
# Auth method: OAuth 2.0 Client Credentials via Azure AD
# Setup: Register app in Azure Portal → grant BC API permissions
# Docs: https://learn.microsoft.com/en-us/dynamics365/business-central/dev-itpro/api-reference/v2.0/
# ─────────────────────────────────────────────
BC_TENANT_ID=your-azure-tenant-id
BC_CLIENT_ID=your-azure-app-client-id
BC_CLIENT_SECRET=your-azure-app-client-secret
BC_ENVIRONMENT=production
BC_COMPANY_ID=your-bc-company-guid
BC_WEBHOOK_SECRET=choose-a-strong-random-string

# ─────────────────────────────────────────────
# FEDEX REST API
# Auth method: OAuth 2.0 Client Credentials
# Setup: developer.fedex.com → Create App → enable Track, Ship, Notifications APIs
# Use FEDEX_ENV=sandbox for testing, production for live
# Docs: https://developer.fedex.com/api/en-us/home.html
# ─────────────────────────────────────────────
FEDEX_API_KEY=your-fedex-api-key
FEDEX_SECRET_KEY=your-fedex-secret-key
FEDEX_ACCOUNT_NUMBER=your-fedex-account-number
FEDEX_ENV=sandbox
FEDEX_WEBHOOK_SECRET=choose-a-strong-random-string

# ─────────────────────────────────────────────
# RINGCENTRAL
# Auth method: JWT (server-to-server, no user login required)
# Setup: developers.ringcentral.com → Create App (Server/No UI) → JWT Credentials
# Scopes needed: ReadCallLog, Analytics, ReadAccounts, Subscriptions
# Docs: https://developers.ringcentral.com/guide/authentication/jwt-flow
# ─────────────────────────────────────────────
RINGCENTRAL_CLIENT_ID=your-rc-app-client-id
RINGCENTRAL_CLIENT_SECRET=your-rc-app-client-secret
RINGCENTRAL_JWT_TOKEN=your-rc-jwt-credential
RINGCENTRAL_ACCOUNT_ID=~
RINGCENTRAL_WEBHOOK_SECRET=choose-a-strong-random-string
